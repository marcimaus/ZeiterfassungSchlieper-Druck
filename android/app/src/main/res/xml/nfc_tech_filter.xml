<?xml version="1.0" encoding="utf-8"?>
<!--
  NFC Tech-Filter für die Zeiterfassungs-App.
  Deckt alle gängigen NFC-Chipkarten ab (Mifare, ISO-14443, ISO-15693 etc.).
  Wird im AndroidManifest.xml als meta-data in der MainActivity referenziert.
-->
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <tech-list>
        <!-- ISO 14443-3A (NfcA) – Mifare Classic, Mifare Ultralight -->
        <tech>android.nfc.tech.NfcA</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 14443-3B (NfcB) -->
        <tech>android.nfc.tech.NfcB</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 15693 (NfcV) – Vicinity-Karten -->
        <tech>android.nfc.tech.NfcV</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 18092 (NfcF) – FeliCa -->
        <tech>android.nfc.tech.NfcF</tech>
    </tech-list>
    <tech-list>
        <!-- NDEF-formatierte Tags -->
        <tech>android.nfc.tech.Ndef</tech>
    </tech-list>
    <tech-list>
        <!-- Mifare Classic -->
        <tech>android.nfc.tech.MifareClassic</tech>
    </tech-list>
    <tech-list>
        <!-- Mifare Ultralight -->
        <tech>android.nfc.tech.MifareUltralight</tech>
    </tech-list>
</resources>
